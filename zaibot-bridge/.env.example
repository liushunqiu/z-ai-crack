# ============================================================================
# Z.ai Bridge 配置文件
# 复制此文件为 .env 并按需修改: cp .env.example .env
# ============================================================================

# --- 网络请求路径 ---
# 默认: DOM Fetch（Camoufox 浏览器同时拿 captcha 和发 chat API，TLS 指纹一致，推荐）
# 不设置 ZAIBOT_USE_PURE_HTTP 即可。
#
# 已废弃: Pure HTTP (ZAIBOT_USE_PURE_HTTP=1) 会触发 Aliyun WAF TLS 指纹关联 → verify_failed
# 仅在 DOM Fetch 路径彻底不可用时作为应急回退:
# ZAIBOT_USE_PURE_HTTP=1

# --- 代理配置 ---
# 全局回退代理（仅当账号 proxy 为空时使用）
# 每账号独立代理请在 admin UI 设置: http://127.0.0.1:8001/admin
# SOCKS5 代理（推荐，绕过 IP 级 WAF）
# 需要安装: pip install pysocks && pip install camoufox[geoip]
ZAIBOT_PROXY=socks5://127.0.0.1:33211

# 或使用 HTTP 代理（可能被 WAF 拦截）
# ZAIBOT_PROXY=http://127.0.0.1:33210

# --- 服务配置 ---
# 绑定地址（默认 127.0.0.1，如需远程访问改为 0.0.0.0）
ZAIBOT_HOST=127.0.0.1

# Admin API 密钥（未设置时仅允许本机访问 /admin/*）
# ZAIBOT_ADMIN_KEY=your-secret-key

# CORS 允许来源（默认 *，多来源用逗号分隔）
# ZAIBOT_CORS_ORIGINS=*

# --- 签名配置 ---
# X-Signature HMAC 密钥（设置后签名实时计算，无需 captured_request.json）
# ZAIBOT_HMAC_SECRET=key-@@@@)))()((9))-xxxx&&&%%%%%
